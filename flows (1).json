    {
        "id": "func_motion",
        "type": "function",
        "z": "6820eaa3e12609a8",
        "name": "Motion Publisher",
        "func": "var motionStates = [\"detected\", \"clear\"];\nvar status = motionStates[Math.floor(Math.random() * 2)];\n\nmsg.payload = JSON.stringify({\n    sensor: \"motion_01\",\n    status: status,\n    location: \"livingroom\",\n    timestamp: new Date().toISOString()\n});\nmsg.topic = \"home_akshaya/livingroom/motion\";\nmsg.qos = 1;\nmsg.retain = false;\nreturn msg;",
        "outputs": 1,
        "x": 520,
        "y": 260,
        "wires": [
            [
                "mqtt_motion"
            ]
        ]
    },
