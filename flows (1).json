    {
        "id": "func_temp",
        "type": "function",
        "z": "6820eaa3e12609a8",
        "name": "Temperature Publisher",
        "func": "var temp = (20 + Math.random() * 10).toFixed(1);\nvar humidity = (40 + Math.random() * 30).toFixed(1);\n\nmsg.payload = JSON.stringify({\n    sensor: \"temp_01\",\n    temperature: parseFloat(temp),\n    humidity: parseFloat(humidity),\n    unit: \"celsius\",\n    timestamp: new Date().toISOString()\n});\nmsg.topic = \"home_akshaya/livingroom/temperature\";\nmsg.qos = 1;\nmsg.retain = false;\nreturn msg;",
        "outputs": 1,
        "x": 520,
        "y": 180,
        "wires": [
            [
                "mqtt_temp"
            ]
        ]
    },
    {
        "id": "mqtt_temp",
        "type": "mqtt out",
        "z": "6820eaa3e12609a8",
